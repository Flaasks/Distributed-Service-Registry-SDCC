FROM golang:1.24-alpine AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/demo-service ./cmd/demo-service

FROM alpine:3.20

WORKDIR /app
COPY --from=builder /out/demo-service /usr/local/bin/demo-service
COPY config /app/config

ENTRYPOINT ["demo-service"]
CMD ["-config", "/app/config/demo-service.docker.yaml"]
